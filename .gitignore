# ============================================
# AI COMBINER PROJECT - SECURITY .gitignore
# ============================================
# КРИТИЧНО: Этот файл защищает от утечки секретов
# Всегда проверяйте перед коммитом: git status

# ============================================
# 1. СЕКРЕТЫ И КЛЮЧИ API
# ============================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets.json
config/secrets/
*.secret

# API Keys для AI сервисов
*api_key*
*apikey*
*API_KEY*
anthropic_key*
openai_key*
huggingface_token*
openrouter_key*

# ============================================
# 2. ПЕРСОНАЛЬНЫЕ ДАННЫЕ И ПУТИ
# ============================================
# Базы данных с реальными путями
*.db
*.sqlite
*.sqlite3
local_db/
database/
db_backups/

# Логи с потенциально sensitive info
*.log
logs/
*.log.*
combined.log
error.log

# История команд и конфигов
.bash_history
.zsh_history
*.history
.claude_history

